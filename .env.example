SECRET_KEY=change-me-to-a-random-secret-key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
DATABASE_URL=postgres://portability_user:password@localhost:5432/portability_db

# OAuth credentials
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_SANDBOX_MODE=False

# OAuth callback URLs (must match what is registered with each provider)
GOOGLE_REDIRECT_URI=
TIKTOK_REDIRECT_URI=

# Encryption (base64 urlsafe Fernet key; falls back to SECRET_KEY if empty)
ENCRYPTION_KEY=

# Celery / Redis
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/1
